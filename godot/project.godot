[layer_names]

3d_physics/layer_1="terrain"
3d_physics/layer_2="buildings"
3d_physics/layer_3="vehicles"

[physics]

common/physics_ticks_per_second=120
3d/default_gravity=9.81

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.45, 0.6, 0.75, 1)
anti_aliasing/quality/msaa_3d=2
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
environment/volumetric_fog/volume_size=128
